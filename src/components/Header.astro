---
const links = [
  { href: '/', label: 'Home' },
  { href: '/writing', label: 'Writing' },
  { href: '/book', label: 'Book' },
  { href: '/about', label: 'About' },
];
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="site-header">
  <div class="wrap bar">
    <a class="brand" href="/">
      <img class="mark" src="/photo.jpg" width="34" height="34" alt="Bhavy Khatri" loading="eager" decoding="async" />
      <span class="name">Bhavy Khatri</span>
    </a>

    <nav class="nav" aria-label="Primary">
      {
        links.map((l) => {
          const active = l.href === '/' ? path === '/' : path.startsWith(l.href);
          return (
            <a href={l.href} class={active ? 'active' : ''}>
              {l.label}
            </a>
          );
        })
      }
      <button id="theme-toggle" class="toggle" aria-label="Toggle color theme" title="Toggle theme">
        <svg class="sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
        </svg>
        <svg class="moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
        </svg>
      </button>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: saturate(160%) blur(12px);
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    border-bottom: 1px solid var(--border);
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 600;
  }
  .mark {
    display: block;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
  }
  .name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    letter-spacing: -0.01em;
  }
  .nav {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .nav a {
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--muted);
    transition: color 0.2s ease, background 0.2s ease;
  }
  .nav a:hover { color: var(--text); background: var(--bg-soft); }
  .nav a.active { color: var(--accent); }
  .toggle {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    margin-left: 0.35rem;
    border-radius: 999px;
    border: 1px solid var(--border-solid);
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .toggle:hover { border-color: var(--accent); transform: rotate(-12deg); }
  .toggle .moon { display: none; }
  [data-theme='dark'] .toggle .sun { display: none; }
  [data-theme='dark'] .toggle .moon { display: block; }

  @media (max-width: 560px) {
    .name { display: none; }
    .nav a { padding: 0.4rem 0.55rem; font-size: 0.88rem; }
  }
</style>

<script is:inline>
  (function () {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', function () {
      const cur = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
      const next = cur === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      try { localStorage.setItem('theme', next); } catch (e) {}
    });
  })();
</script>
