---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('writing', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { title, date, kind, lang, tags } = post.data;
const { Content } = await post.render();
const fmtDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

// Related posts of the same kind
const all = (await getCollection('writing', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const related = all.filter((p) => p.data.kind === kind && p.slug !== post.slug).slice(0, 3);
---

<Base title={title} description={post.data.excerpt}>
  <article class={`post ${kind}`}>
    <div class="wrap narrow">
      <a class="back" href="/writing">← All writing</a>
      <div class="post-meta">
        <span class={`kind ${kind}`}>{kind === 'poetry' ? 'Poetry' : 'Essay'}</span>
        <time datetime={date.toISOString()}>{fmtDate}</time>
      </div>
      <h1 class={lang === 'hi' ? 'deva' : ''}>{title}</h1>

      <div class={`content ${lang === 'hi' ? 'deva' : ''} ${kind}`}>
        <Content />
      </div>

      {
        tags.length > 0 && (
          <div class="tags">
            {tags.map((t) => <span class="tag">#{t}</span>)}
          </div>
        )
      }
    </div>
  </article>

  {
    related.length > 0 && (
      <section class="related">
        <div class="wrap narrow">
          <h2>{kind === 'poetry' ? 'More poems' : 'More essays'}</h2>
          <ul>
            {related.map((p) => (
              <li>
                <a href={`/writing/${p.slug}`} class={p.data.lang === 'hi' ? 'deva' : ''}>
                  {p.data.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }
</Base>

<style>
  .narrow { max-width: var(--readw); }
  .post { padding: 3rem 0 1rem; }
  .back { color: var(--muted); font-size: 0.9rem; font-weight: 500; }
  .back:hover { color: var(--accent); }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin: 1.8rem 0 0.8rem;
    font-size: 0.82rem;
    color: var(--faint);
  }
  .kind {
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-size: 0.68rem;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
  }
  .kind.poetry { color: var(--accent); background: color-mix(in srgb, var(--accent) 12%, transparent); }
  .kind.essay { color: var(--gold); background: color-mix(in srgb, var(--gold) 14%, transparent); }

  .post h1 {
    font-size: clamp(1.9rem, 4.5vw, 2.9rem);
    margin: 0 0 1.6rem;
  }
  .post h1.deva { line-height: 1.4; }

  /* Essay body */
  .content {
    font-family: var(--font-serif);
    font-size: 1.16rem;
    line-height: 1.8;
    color: var(--text);
  }
  .content :global(p) { margin: 0 0 1.35rem; }
  .content :global(h2) { font-size: 1.6rem; margin: 2.5rem 0 1rem; }
  .content :global(h3) { font-size: 1.28rem; margin: 2rem 0 0.8rem; }
  .content :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .content :global(blockquote) {
    margin: 1.6rem 0;
    padding: 0.4rem 0 0.4rem 1.4rem;
    border-left: 3px solid var(--accent);
    color: var(--muted);
    font-style: italic;
  }
  .content :global(img) { border-radius: 12px; margin: 1.8rem auto; box-shadow: var(--shadow); }
  .content :global(pre) {
    background: var(--bg-soft);
    border: 1px solid var(--border-solid);
    border-radius: 12px;
    padding: 1.1rem 1.25rem;
    overflow-x: auto;
    font-size: 0.92rem;
    line-height: 1.6;
  }
  .content :global(code) { font-size: 0.92em; }

  /* Poetry body: centered, airy, serif Devanagari */
  .content.poetry {
    font-family: var(--font-deva);
    text-align: center;
    font-size: 1.4rem;
    line-height: 2.15;
  }
  .content.poetry :global(p) { text-align: center; }
  .content.deva { font-family: var(--font-deva); }

  .tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 2.5rem 0 1rem; }

  .related {
    margin-top: 3rem;
    border-top: 1px solid var(--border);
    padding: 2.5rem 0 1rem;
  }
  .related h2 { font-size: 1.4rem; margin: 0 0 1rem; }
  .related ul { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.6rem; }
  .related a {
    color: var(--muted);
    font-family: var(--font-serif);
    font-size: 1.08rem;
    transition: color 0.2s ease;
  }
  .related a:hover { color: var(--accent); }

  @media (max-width: 640px) {
    .content { font-size: 1.08rem; }
    .content.poetry { font-size: 1.24rem; line-height: 2; }
  }
</style>
