---
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import BookFeature from '../components/BookFeature.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const recent = posts.slice(0, 4);
const poemCount = posts.filter((p) => p.data.kind === 'poetry').length;
const essayCount = posts.filter((p) => p.data.kind === 'essay').length;
---

<Base>
  <!-- Hero -->
  <section class="hero">
    <div class="wrap grid">
      <div class="intro">
        <span class="eyebrow">Bhavy Khatri</span>
        <h1>
          I build software that <em>solves</em>,<br />
          and write words that <em>linger</em>.
        </h1>
        <p class="lede">
          Full-stack developer at <strong>Microsoft</strong> and a Computer Science graduate from
          <strong>IIT Kanpur</strong>. By day I ship products end to end; by night I write essays
          and compose Hindi-Urdu poetry.
        </p>
        <div class="actions">
          <a class="btn btn-primary" href="/writing">Read my writing <span aria-hidden="true">→</span></a>
          <a class="btn btn-ghost" href="/book">The Agents book</a>
        </div>
        <div class="stats">
          <div><span class="n">{poemCount}</span><span class="l">poems</span></div>
          <div><span class="n">{essayCount}</span><span class="l">essays</span></div>
          <div><span class="n">1</span><span class="l">book in progress</span></div>
        </div>
      </div>

      <div class="portrait reveal">
        <img src="/photo.jpg" alt="Bhavy Khatri" width="360" height="360" loading="eager" />
      </div>
    </div>
  </section>

  <!-- Book feature -->
  <section class="section-pad">
    <div class="wrap">
      <BookFeature />
    </div>
  </section>

  <!-- Recent writing -->
  <section class="section-pad writing-preview">
    <div class="wrap">
      <div class="head reveal">
        <div>
          <span class="eyebrow">From the notebook</span>
          <h2>Recent writing</h2>
        </div>
        <a class="more" href="/writing">All writing →</a>
      </div>
      <div class="grid-posts">
        {recent.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </section>
</Base>

<style>
  .hero { padding: 4.5rem 0 2rem; }
  .grid {
    display: grid;
    grid-template-columns: 1.25fr 0.75fr;
    gap: 3.5rem;
    align-items: center;
  }
  .intro h1 {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    margin: 0.6rem 0 1.1rem;
  }
  .intro h1 em { font-style: italic; color: var(--accent); }
  .lede {
    font-size: 1.12rem;
    color: var(--muted);
    max-width: 40ch;
    margin: 0 0 1.8rem;
  }
  .lede strong { color: var(--text); font-weight: 600; }
  .actions { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-bottom: 2.4rem; }
  .stats { display: flex; gap: 2.5rem; }
  .stats .n {
    display: block;
    font-family: var(--font-display);
    font-size: 1.8rem;
    line-height: 1;
    color: var(--accent);
  }
  .stats .l { font-size: 0.82rem; color: var(--faint); letter-spacing: 0.04em; }

  .portrait { position: relative; justify-self: center; }
  .portrait img {
    width: min(360px, 78vw);
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 26px;
    border: 1px solid var(--border-solid);
    box-shadow: var(--shadow-lg);
    filter: saturate(1.02);
  }

  .head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 2rem;
  }
  .head h2 { font-size: 2rem; margin: 0.4rem 0 0; }
  .more { color: var(--accent); font-weight: 550; font-size: 0.95rem; }
  .grid-posts {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
  }

  @media (max-width: 860px) {
    .grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .portrait { order: -1; }
  }
</style>
