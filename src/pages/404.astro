---
import Base from '../layouts/Base.astro';
---

<Base title="Not found" description="This page could not be found.">
  <section class="nf">
    <div class="wrap">
      <span class="big deva">कहीं नहीं</span>
      <h1>404 — lost in translation</h1>
      <p class="muted">The page you were looking for has wandered off. Let's get you back.</p>
      <div class="actions">
        <a class="btn btn-primary" href="/">Home</a>
        <a class="btn btn-ghost" href="/writing">Writing</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .nf { padding: 6rem 0; text-align: center; }
  .big { display: block; font-size: clamp(3rem, 12vw, 7rem); color: var(--accent); line-height: 1; opacity: 0.9; }
  .nf h1 { font-size: clamp(1.6rem, 4vw, 2.4rem); margin: 1rem 0 0.6rem; }
  .actions { display: flex; gap: 0.8rem; justify-content: center; margin-top: 1.6rem; }
</style>
